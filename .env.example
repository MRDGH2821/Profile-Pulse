# Profile Pulse Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_PATH=profile-pulse.db
DB_MAX_CONNECTIONS=10

# Logging
# Options: debug, info, warn, error
RUST_LOG=profile_pulse=info,warn
DEBUG=0

# Social Media API Keys (Optional)
# GitHub Personal Access Token (for higher rate limits)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Twitter/X API Bearer Token (required for Twitter integration)
# Get one at: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# Google Custom Search API (for profile discovery)
# Get credentials at: https://developers.google.com/custom-search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Application Settings
# Directory paths (leave empty to use system defaults)
DATA_DIR=
CACHE_DIR=

# Cache settings (in days)
CACHE_TTL_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Development Settings
# Set to 1 to enable hot reloading and verbose logging
DEV_MODE=0